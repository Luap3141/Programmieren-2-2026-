#include <cmath>
#include <stdexcept>

class Segment {
	double x1;
	double y1;
	double x2;
	double y2;
public:
	Segment(double StartX, double StartY, double EndX, double EndY) {
		x1 = StartX;
		y1 = StartY;
		x2 = EndX;
		y2 = EndY;
	}
	const double angle() {
		double x = abs(x2-x1)/abs(y2-y1);
		return std::atan(x);
	}
	const double slope() {
		return (y2-y1)/(x2-x1);
	}
	const double constpart() {
		return y1 -x1*y2/x2;
	}
	const double length() {
		return std::sqrt(std::pow((x2-x1),2) + std::pow((y1-y1),2));
	}
	bool collides()
	void collision(Segment& other) {
		if (slope() = other.slope()) {
			throw std::runtime
		}
		double det = 1/(slope() - other.slope());
		x2 = det*(other.constpart()-constpart());
		y2 = det*(other.constpart()*slope()-constpart()*other.slope());
	}
};
