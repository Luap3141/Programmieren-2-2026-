#include "TemplateRecursive.h"
#include <string>
#include <stdexcept>

template<class Ring> void RecPoly<Ring>::sanitize() {
	for (auto i = coeffs.length() - 1; i >= 0; i--) {
		if (coeffs[i] != Ring::zero())
			return;
		}
		coeffs.pop_back();
	}
}

template<class Ring> RecPoly* RecPoly<Ring>::operator+(RecPoly &other) {
	if (this->variable != other->variable) {
		//Maybe more refined behaviour can be added later
		throw invalid_argument("Polynomials of different variable added")
	}
	vector<Ring> output(max(this->coeffs.size(),other->coeffs.size()));
	if (this->coeffs.size() < other->coeffs.size()) {
		for (auto i = 0; i < this->coeffs.size(); i++) {
			output[i] = this->coeffs[i] + other->coeffs[i];
		}
		for (auto i = this->coeffs.size(); i < other->coeffs.size(); i++) {
			output[i] = other->coeffs[i];
		}
	} else {
		for (auto i = 0; i < other->coeffs.size(); i++) {
				output[i] = this->coeffs[i] + other->coeffs[i];
			}
			for (auto i = other->coeffs.size(); i < this->coeffs.size(); i++) {
				output[i] = this->coeffs[i];
			}
	}
	RecPoly* out(output,this->variable);
	out->sanitize();
	return out;
}

template<class Ring> RecPoly* RecPoly<Ring>::operator*(RecPoly &other) {
	if (this->variable != other->variable) {
		//Maybe more refined behaviour can be added later
		throw invalid_argument("Polynomials of different variable multiplied");
	}
	vector<Ring> output(this->coeffs.size() + other->coeffs.size());
	for (int i = 0; i < this->coeffs.size() + other->coeffs.size(); i++) {
		output[i] = 0;
		for (int j = 0; j < i + 1; j++) {
			Ring* summand1 = Ring::zero();
			Ring* summand2 = Ring::zero();
			if (this->coeffs.length() >= j-1) {
				summand1 = this->coeffs[j];
			}
			if (other->coeffs.length() <= i-j-1) {
				summand2 = other->coeffs[j-1];
			}
			output[i] = output[i] + summand1->operator+(summand2);
		}
	}
	RecPoly* out(output,this->variable);
	out->sanitize();
	return out;
}

